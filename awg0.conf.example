# =============================================================
# AmneziaWG client config for GT-AX11000
# =============================================================
# This file is used by: awg setconf awg0 /opt/amneziawg/awg0.conf
#
# NOTE: Address and DNS are NOT handled by awg tool.
#       Set address separately:
#         echo "10.7.0.2/24" > /opt/amneziawg/awg0.addr
#       Set DNS on router via nvram or /etc/resolv.conf
#
# Obfuscation parameters MUST match the server config exactly.
# Generate them on the server with Amnezia VPN client or manually.
# =============================================================

[Interface]
PrivateKey = <YOUR_PRIVATE_KEY>
ListenPort = 51820

# --- AmneziaWG 2.0 obfuscation parameters ---
# Junk packets before handshake (0-10)
Jc = 4
# Junk packet size range (bytes)
Jmin = 40
Jmax = 70

# Handshake padding (bytes, 0-64)
S1 = 20
S2 = 30

# Magic headers (must NOT overlap, 0-4294967295)
H1 = 1234567891
H2 = 1987654321
H3 = 1112223334
H4 = 4445556667

[Peer]
PublicKey = <SERVER_PUBLIC_KEY>
PresharedKey = <OPTIONAL_PRESHARED_KEY>
Endpoint = <SERVER_IP>:51820
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
