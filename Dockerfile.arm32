# =============================================================
# AmneziaWG tools (awg) builder for ARM32
# Static musl binary — works on both armel and armhf
# =============================================================
FROM --platform=linux/amd64 alpine:3.19 AS builder

RUN apk add --no-cache make curl tar git

# musl.cc cross-toolchain (soft-float, static musl libc)
RUN curl -L https://musl.cc/arm-linux-musleabi-cross.tgz | tar xz -C /opt
ENV PATH="/opt/arm-linux-musleabi-cross/bin:${PATH}"

RUN git clone --depth 1 --branch v1.0.20260223 \
        https://github.com/amnezia-vpn/amneziawg-tools.git

RUN cd amneziawg-tools/src && \
    make CC=arm-linux-musleabi-gcc \
         LDFLAGS=-static \
         PLATFORM_CFLAGS="" && \
    mkdir -p /output && \
    (cp awg /output/awg-arm 2>/dev/null || cp wg /output/awg-arm) && \
    chmod +x /output/awg-arm && \
    echo "--- awg-arm info ---" && \
    file /output/awg-arm && \
    ls -lh /output/awg-arm

FROM scratch AS export
COPY --from=builder /output/ /
